# DarkPulse — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Tor / Proxy ─────────────────────────────────────────────────────────────
# Leave empty to disable proxy (clears net scraping only, no Tor)
TOR_PROXY_URL=socks5://127.0.0.1:9150

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=darkpulse

# ── GitHub ───────────────────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens (read:repo scope)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ── API Server ────────────────────────────────────────────────────────────────
# Set a strong random string — clients must send: X-API-Key: <value>
# Leave empty to disable authentication (not recommended for production)
API_KEY=YOUR_STRONG_RANDOM_API_KEY_HERE

# Comma-separated allowed CORS origins. Use * only for local dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

API_HOST=0.0.0.0
API_PORT=8000

# ── Collector Defaults ────────────────────────────────────────────────────────
MAX_PAGES=5
MAX_ARTICLES=50

# ── Scheduler (orchestrator.py) ───────────────────────────────────────────────
# How often all collectors run (in hours)
SCHEDULE_INTERVAL_HOURS=6

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
