# DarkPulse — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Tor / Proxy ─────────────────────────────────────────────────────────────
# Leave empty to disable proxy (clears net scraping only, no Tor)
TOR_PROXY_URL=socks5://127.0.0.1:9150

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB=darkpulse

# ── GitHub ───────────────────────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens (read:repo scope)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE
GEMINI_API_KEY=
PAGESPEED_API_KEY=

# ── API Server ────────────────────────────────────────────────────────────────
# Set a strong random string — clients must send: X-API-Key: <value>
# Leave empty to disable authentication (not recommended for production)
API_KEY=YOUR_STRONG_RANDOM_API_KEY_HERE

# Comma-separated allowed CORS origins. Use * only for local dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

API_HOST=0.0.0.0
API_PORT=8000

# ── Collector Defaults ────────────────────────────────────────────────────────
MAX_PAGES=5
MAX_ARTICLES=50
MANUAL_SCAN_NEWS_MAX_PAGES=3
MANUAL_SCAN_NEWS_MAX_ARTICLES=60
MANUAL_SCAN_LEAKS_MAX_PAGES=2
MANUAL_SCAN_LEAKS_MAX_ARTICLES=80
MANUAL_SCAN_SOCIAL_MAX_PAGES=2
MANUAL_SCAN_SOCIAL_MAX_ARTICLES=80
MANUAL_SCAN_DEFACEMENT_MAX_PAGES=3
MANUAL_SCAN_DEFACEMENT_MAX_ARTICLES=120

# ── Scheduler (orchestrator.py) ───────────────────────────────────────────────
# How often all collectors run (in hours)
SCHEDULE_INTERVAL_HOURS=6

# ── HTML Healing Monitor ──────────────────────────────────────────────────────
# Discovers scraper targets, stores HTML snapshots, detects DOM changes, and
# proposes selector repairs for monitored scripts.
HEALING_MONITOR_ENABLED=false
HEALING_MONITOR_INTERVAL_MINUTES=180
HEALING_MONITOR_TARGET_LIMIT=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── One-Click Automated Intelligence Update ──────────────────────────────────
# Optional: n8n webhook that receives secure scan_started / scan_completed events
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# User-facing Arya delivery label shown in dashboard notifications
# Examples: Dashboard Alert, Telegram, Slack, Email
ARYA_NOTIFICATION_CHANNEL=Dashboard Alert
